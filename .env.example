TRUENAS_WS_URL=wss://truenas.example.local/api/current
TRUENAS_API_KEY=replace_with_api_key
TRUENAS_VERIFY_TLS=true
EXPORTER_PORT=9108
SCRAPE_INTERVAL_SECONDS=30
TRUENAS_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
EXPORTER_MODE=legacy

AUTO_DISCOVER_METHODS=false
SCRAPE_ALL_METRICS=false
QUERY_LIMIT=200
MAX_METHOD_CALLS=250
MAX_LIST_ITEMS=200
MAX_METRIC_DEPTH=6
MAX_ENTITY_CALLS=50
MAX_DATASETS=100

FILESYSTEM_PATHS=/mnt
ENABLE_FILESYSTEM_LISTDIR=false

ENABLE_EVENT_STREAMS=true
EVENT_INTERVAL_SECONDS=2
EVENT_READ_TIMEOUT_SECONDS=60
EVENT_SUBSCRIPTIONS=reporting.realtime,app.stats,virt.instance.metrics,pool.scan,pool.query,disk.query,docker.state,interface.query,alert.list,directoryservices.status,service.query,failover.status,update.status,system.reboot.info,system.shutdown,core.get_jobs,container.query,vm.query

ENABLE_DATASET_METRICS=true
ENABLE_TASK_METRICS=true
ENABLE_IPMI_METRICS=true

ENABLE_GENERIC_METHOD_METRICS=false
ENABLE_GENERIC_EVENT_METRICS=false
DATASET_SNAPSHOT_FALLBACK_LIMIT=0

EXTRA_METHODS=
EXCLUDE_METHODS=
